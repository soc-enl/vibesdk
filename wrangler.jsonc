{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "vibesdk-app",
	"compatibility_date": "2026-03-28",
	"compatibility_flags": ["nodejs_compat"],
	"upload_source_maps": true,
	"observability": {
		"enabled": true
	},
	"pages_build_output_dir": "dist",
	"vars": {
		"API_URL": "https://vibesdk.megabyte.app"
	}
}
